# Bloom Dev Toolbox — Fedora 43 development environment
# Build:  podman build -t bloom-dev-toolbox -f toolbox/Containerfile toolbox/
# Create: toolbox create --image bloom-dev-toolbox bloom-dev
# Enter:  toolbox enter bloom-dev
FROM registry.fedoraproject.org/fedora-toolbox:43

# ── System dev tools ──────────────────────────────────────────────
RUN dnf install -y \
    git \
    git-lfs \
    ripgrep \
    fd-find \
    jq \
    bat \
    htop \
    just \
    ShellCheck \
    openssl \
    openssh-clients \
    curl \
    wget \
    unzip \
    && dnf clean all

# ── Virtualization (QEMU + OVMF for VM testing) ──────────────────
RUN dnf install -y \
    qemu-system-x86 \
    edk2-ovmf \
    && dnf clean all

# ── Podman (container builds) ────────────────────────────────────
RUN dnf install -y \
    podman \
    buildah \
    skopeo \
    && dnf clean all

# ── Node.js (latest LTS via NodeSource) ──────────────────────────
RUN curl -fsSL https://rpm.nodesource.com/setup_22.x | bash - \
    && dnf install -y nodejs \
    && dnf clean all

# ── Global npm tools ─────────────────────────────────────────────
RUN npm install -g \
    @anthropic-ai/claude-code \
    @mariozechner/pi-coding-agent \
    @biomejs/biome \
    typescript

# ── VS Code repo ─────────────────────────────────────────────────
RUN rpm --import https://packages.microsoft.com/keys/microsoft.asc \
    && printf "[code]\nname=Visual Studio Code\nbaseurl=https://packages.microsoft.com/yumrepos/vscode\nenabled=1\ngpgcheck=1\ngpgkey=https://packages.microsoft.com/keys/microsoft.asc\n" > /etc/yum.repos.d/vscode.repo \
    && dnf install -y code \
    && dnf clean all

# ── Labels ────────────────────────────────────────────────────────
LABEL com.github.containers.toolbox="true" \
      name="bloom-dev-toolbox" \
      version="1.0" \
      description="Bloom development environment with Node.js, VS Code, Claude Code, Pi, QEMU"
