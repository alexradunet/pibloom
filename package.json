{
	"name": "pi-platform",
	"version": "0.1.0",
	"description": "Pi-native OS platform on NixOS",
	"type": "module",
	"private": true,
	"engines": {
		"node": ">=22"
	},
	"keywords": [
		"pi-package"
	],
	"pi": {
		"extensions": [
			"./core/pi/extensions/persona",
			"./core/pi/extensions/localai",
			"./core/pi/extensions/os",
			"./core/pi/extensions/episodes",
			"./core/pi/extensions/objects",
			"./core/pi/extensions/nixpi",
			"./core/pi/extensions/setup"
		],
		"skills": [
			"./core/pi/skills"
		]
	},
	"peerDependencies": {
		"@mariozechner/pi-ai": "*",
		"@mariozechner/pi-coding-agent": "*"
	},
	"dependencies": {
		"@sinclair/typebox": "^0.34.0",
		"js-yaml": "^4.1.0",
		"matrix-js-sdk": "^41.1.0"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.0.0",
		"@mariozechner/pi-ai": "0.60.0",
		"@mariozechner/pi-coding-agent": "0.60.0",
		"@types/js-yaml": "^4.0.9",
		"@vitest/coverage-v8": "^4.0.18",
		"typescript": "^5.7.0",
		"vitepress": "^1.6.4",
		"vitest": "^4.0.18"
	},
	"scripts": {
		"test": "vitest run",
		"test:unit": "vitest run tests/lib tests/extensions tests/daemon",
		"test:integration": "vitest run tests/integration",
		"test:e2e": "vitest run tests/e2e",
		"test:ci": "npm run test:unit && npm run test:integration && npm run test:e2e && npm run test:coverage",
		"test:watch": "vitest",
		"test:coverage": "vitest run --coverage",
		"build": "rm -rf dist && tsc --build",
		"check": "biome check .",
		"check:fix": "biome check --write .",
		"docs:dev": "vitepress dev docs",
		"docs:build": "vitepress build docs",
		"docs:preview": "vitepress preview docs"
	}
}
