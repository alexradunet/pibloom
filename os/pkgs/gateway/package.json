{
  "name": "ownloom-gateway",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "tsc -p tsconfig.test.json && node --test dist-test/tests/*.test.js",
    "audit": "npm audit && npm ls --package-lock-only protobufjs --all",
    "example:protocol": "node examples/protocol-client.mjs",
    "start": "node dist/main.js",
    "dev": "tsx src/main.ts"
  },
  "dependencies": {
    "@earendil-works/pi-coding-agent": "0.74.0",
    "@whiskeysockets/baileys": "7.0.0-rc.9",
    "qrcode": "^1.5.4",
    "ws": "^8.20.0",
    "yaml": "^2.5.1"
  },
  "overrides": {
    "@earendil-works/pi-agent-core": "0.74.0",
    "@earendil-works/pi-ai": "0.74.0",
    "@earendil-works/pi-tui": "0.74.0",
    "protobufjs": "^7.5.5"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "@types/qrcode": "^1.5.6",
    "@types/ws": "^8.18.1",
    "tsx": "^4.19.2",
    "typescript": "^5.8.3"
  }
}
