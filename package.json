{
	"name": "bloom",
	"version": "0.1.0",
	"description": "Bloom — Pi-native OS platform on Fedora bootc",
	"type": "module",
	"private": true,
	"engines": {
		"node": ">=22"
	},
	"keywords": [
		"pi-package"
	],
	"pi": {
		"extensions": [
			"./extensions"
		]
	},
	"peerDependencies": {
		"@mariozechner/pi-ai": "*",
		"@mariozechner/pi-coding-agent": "*",
		"@sinclair/typebox": "*"
	},
	"dependencies": {
		"@11ty/gray-matter": "^2.0.1",
		"execa": "^9.6.1",
		"hosted-git-info": "^9.0.2",
		"js-yaml": "^4.1.0",
		"qrcode": "^1.5.4"
	},
	"devDependencies": {
		"@mariozechner/pi-ai": "^0.55.4",
		"@mariozechner/pi-coding-agent": "^0.55.4",
		"@sinclair/typebox": "^0.34.0",
		"@types/hosted-git-info": "^3.0.5",
		"@types/js-yaml": "^4.0.9",
		"@types/qrcode": "^1.5.6",
		"@vitest/coverage-v8": "^4.0.18",
		"typescript": "^5.7.0",
		"vitest": "^4.0.18"
	},
	"scripts": {
		"test": "vitest run",
		"test:watch": "vitest",
		"test:coverage": "vitest run --coverage",
		"build": "rm -rf dist && tsc --build",
		"check": "npx @biomejs/biome check .",
		"check:fix": "npx @biomejs/biome check --write ."
	}
}
